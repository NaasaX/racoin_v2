{
  "require": {
    "php": ">=8.2",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.7",
    "twig/twig": "3.*",
    "illuminate/database": "11.*",
    "monolog/monolog": "^3.6",
    "ext-mysqli": "*",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.10",
    "zircote/swagger-php": "^4.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "controller\\": "controller/",
      "model\\": "model/",
      "db\\": "db/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "lint": "phpcs",
    "openapi": "vendor/bin/openapi --format yaml --output public/openapi.yaml src"
  },
  "config": {
    "allow-plugins": {
      "kylekatarnls/update-helper": true
    }
  }
}
